// This repo is a Go workspace: the zero-dependency core module at the
// root plus the nested modules that pull in third-party dependencies
// (interop codecs, QUIC transport, config, otel). go.work is tracked
// (not gitignored) so a local checkout resolves the nested modules
// against the in-tree core without a published version. See
// CONTRIBUTING.md.
go 1.26.3

use (
	.
	./cmd
	./pkg/codec/protobuf
	./pkg/config
	./pkg/otel
	./pkg/transport/quic
)
